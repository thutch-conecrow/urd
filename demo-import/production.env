# Production overrides — import with --env prod
# Some keys already exist from dev; use --skip-existing to keep dev values untouched
APP_NAME=my-app
APP_URL=https://app.example.com
APP_PORT=8080
APP_DEBUG=false
DB_HOST=db.example.com
DB_PORT=5432
DB_NAME=myapp_prod
DB_USER=app_service
DB_PASSWORD=real_prod_password_here
